<!-- Deploy to /var/ossec/etc/rules/pler_rules.xml on the Wazuh Manager -->
<!-- Reload with: systemctl reload wazuh-manager -->
<group name="pler,execve,">

  <!-- Base rule: all execve events from pler -->
  <rule id="100100" level="0">
    <decoded_as>pler</decoded_as>
    <field name="data.event_type">^execve$</field>
    <description>pler: process execution - $(data.filename) by $(data.username)</description>
  </rule>

  <!-- Failed execve: reconnaissance indicator -->
  <rule id="100101" level="3">
    <if_sid>100100</if_sid>
    <field name="data.success">^false$</field>
    <description>pler: failed execve - $(data.filename) by $(data.username) [retval=$(data.retval)]</description>
  </rule>

  <!-- Recon burst: same tool called 5+ times in 10s from same parent -->
  <rule id="100102" level="5" frequency="5" timeframe="10">
    <if_matched_sid>100100</if_matched_sid>
    <field name="data.filename">whoami|/usr/bin/id$|uname|hostname|ifconfig|ip addr</field>
    <same_field>data.ppid</same_field>
    <description>pler: recon burst - $(data.comm) called repeatedly from same parent PID</description>
  </rule>

  <!-- Shell spawned from web/app process -->
  <rule id="100110" level="10">
    <if_sid>100100</if_sid>
    <field name="data.filename">^/bin/(bash|sh|dash|zsh|ksh)$</field>
    <field name="data.cgroup">php.*fpm|apache2?|nginx|tomcat|gunicorn|uwsgi|node|passenger</field>
    <description>pler: shell spawned from web process - $(data.username) @ $(data.cwd)</description>
  </rule>

  <!-- /dev/tcp reverse shell indicator -->
  <rule id="100111" level="13">
    <if_sid>100100</if_sid>
    <field name="data.argv">/dev/tcp</field>
    <description>pler: CRITICAL - /dev/tcp reverse shell indicator in argv by $(data.username)</description>
  </rule>

  <!-- Network tool from web process -->
  <rule id="100112" level="12">
    <if_sid>100100</if_sid>
    <field name="data.filename">nc$|ncat$|nmap$|socat$|telnet$</field>
    <field name="data.cgroup">php.*fpm|apache2?|nginx|tomcat|gunicorn|uwsgi|node|passenger</field>
    <description>pler: network tool $(data.comm) spawned from web process as $(data.username)</description>
  </rule>

  <!-- Interpreter + socket connect in argv -->
  <rule id="100113" level="11">
    <if_sid>100100</if_sid>
    <field name="data.filename">python3?$|perl$|ruby$|php$</field>
    <field name="data.argv">socket.*connect|connect.*socket|AF_INET|SOCK_STREAM</field>
    <description>pler: interpreter with socket connect in argv - possible reverse shell by $(data.username)</description>
  </rule>

  <!-- Credential access: non-root reading shadow/passwd -->
  <rule id="100120" level="10">
    <if_sid>100100</if_sid>
    <field name="data.argv">/etc/shadow|/etc/passwd</field>
    <field name="data.uid" negate="yes">^0$</field>
    <description>pler: non-root user $(data.username) reading sensitive credential files</description>
  </rule>

  <!-- Defense evasion: history clearing -->
  <rule id="100130" level="8">
    <if_sid>100100</if_sid>
    <field name="data.argv">history -c|HISTFILE=/dev/null|shred.*history|rm.*bash_history|truncate.*history</field>
    <description>pler: shell history evasion attempt by $(data.username)</description>
  </rule>

  <!-- Privilege escalation: sudo/su from web process -->
  <rule id="100140" level="9">
    <if_sid>100100</if_sid>
    <field name="data.filename">^/bin/su$|^/usr/bin/sudo$</field>
    <field name="data.cgroup">php.*fpm|apache2?|nginx|tomcat|gunicorn|uwsgi|node|passenger</field>
    <description>pler: sudo/su attempted from web process as $(data.username)</description>
  </rule>

  <!-- Visibility gap: ring buffer overflow, events were dropped -->
  <rule id="100199" level="12">
    <decoded_as>pler</decoded_as>
    <field name="data.event_type">^monitor_drop$</field>
    <description>pler: VISIBILITY GAP on $(data.hostname) - ring buffer overflow, events lost</description>
  </rule>

</group>
